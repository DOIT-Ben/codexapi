{$SITE_ADDRESS} {
	encode zstd gzip

	request_body {
		max_size 100MB
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	@api {
		path /api/* /v1/*
	}
	header @api Content-Security-Policy "default-src 'none'; frame-ancestors 'none'; base-uri 'none'"

	# Keep the admin console off the public Internet by default.
	# Use an SSH tunnel for admin work, for example:
	#   ssh -L 18080:127.0.0.1:80 root@your-vps
	@public_admin {
		path /admin* /api/v1/admin/*
		not {
			remote_ip private_ranges 127.0.0.1/32 ::1
		}
	}
	respond @public_admin 404

	@static {
		path /assets/* /logo.png /favicon.ico
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# You are using manual recharge. Keep public payment endpoints closed.
	@public_payment {
		path /payment* /api/v1/payment/*
	}
	respond @public_payment 404

	reverse_proxy sub2api:8080 {
		header_up X-Real-IP {remote_host}
		# Do not pass client-supplied Cloudflare IP headers by default.
		# If production origin traffic is firewalled to Cloudflare only, you may
		# re-enable trusted real-client-IP handling deliberately.
		header_up -CF-Connecting-IP
		transport http {
			keepalive 120s
			keepalive_idle_conns 128
			compression off
		}
	}

	log {
		output file /var/log/caddy/access.log {
			roll_size 50mb
			roll_keep 10
			roll_keep_for 720h
		}
		format json
	}
}
