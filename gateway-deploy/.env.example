# Sub2API Gateway deployment environment
# Copy to .env, then run scripts/init-secrets.ps1 on Windows or scripts/init-secrets.sh on Linux.

# Local preview:
#   SITE_ADDRESS=:80
#   PUBLIC_HTTP_PORT=18080
#   APP_BASE_URL=http://localhost:18080
#
# Production with a domain:
#   SITE_ADDRESS=api.example.com
#   PUBLIC_HTTP_PORT=80
#   PUBLIC_HTTPS_PORT=443
#   APP_BASE_URL=https://api.example.com

SITE_ADDRESS=:80
PUBLIC_HTTP_PORT=18080
PUBLIC_HTTPS_PORT=18443
APP_BASE_URL=http://localhost:18080
TZ=Asia/Shanghai

SUB2API_IMAGE=weishaw/sub2api:latest
SERVER_MODE=release
RUN_MODE=standard

# Admin is created on first boot. Change these before production.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# Persistent secrets. Do not rotate these casually after users exist.
JWT_SECRET=CHANGE_ME_JWT_SECRET_HEX_32_BYTES
TOTP_ENCRYPTION_KEY=CHANGE_ME_TOTP_HEX_32_BYTES

# Database and Redis are internal-only in docker-compose.yml.
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_DB=sub2api
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0

# CORS should be your public site origin in production.
CORS_ALLOWED_ORIGINS=http://localhost:18080
CORS_ALLOW_CREDENTIALS=true
SERVER_TRUSTED_PROXIES=172.16.0.0/12,127.0.0.1/32

# Security: only allow configured upstream hosts.
# For your NexaHub test upstream, keep ai.nexahub.one here.
SECURITY_URL_ALLOWLIST_ENABLED=true
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=false
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=false
SECURITY_URL_ALLOWLIST_UPSTREAM_HOSTS=ai.nexahub.one
# Safer default: do not trust user-controlled forwarded IP headers for API key IP ACL.
# Turn this on only after the VPS firewall allows origin traffic from Cloudflare/proxy IPs only.
SECURITY_TRUST_FORWARDED_IP_FOR_API_KEY_ACL=false
SECURITY_PROXY_FALLBACK_ALLOW_DIRECT_ON_ERROR=false

# Keep payment provider secrets empty. You are using manual recharge.
PAYMENT_RESUME_SIGNING_KEY=

# Conservative defaults for a 20-user small gateway.
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
REDIS_POOL_SIZE=256
REDIS_MIN_IDLE_CONNS=10
GATEWAY_MAX_BODY_SIZE=268435456
SERVER_MAX_REQUEST_BODY_SIZE=268435456
GATEWAY_IMAGE_CONCURRENCY_ENABLED=true
GATEWAY_IMAGE_CONCURRENCY_MAX_CONCURRENT_REQUESTS=2
GATEWAY_IMAGE_CONCURRENCY_OVERFLOW_MODE=reject
GATEWAY_IMAGE_CONCURRENCY_WAIT_TIMEOUT_SECONDS=30
GATEWAY_IMAGE_CONCURRENCY_MAX_WAITING_REQUESTS=20
